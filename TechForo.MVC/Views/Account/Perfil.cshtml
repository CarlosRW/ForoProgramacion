@model TechForo.Models.Vista_de_modelos.PerfilUsuarioViewModel
@{
    ViewBag.Title = "Mi perfil";
}

<h2 class="mb-4">Configuración de perfil</h2>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">@TempData["MensajeExito"]</div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="ds-profile-card">
            <div class="ds-avatar-edit">
                <span class="ds-avatar ds-avatar-lg" id="avatarPreview">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" id="avatarImg" />
                    }
                    else
                    {
                        <span id="avatarIniciales">@Model.Iniciales</span>
                    }
                </span>
                <span class="ds-avatar-edit-btn" title="Cambiar foto" onclick="document.getElementById('avatarFileInput').click();">✎</span>
                <input type="file" id="avatarFileInput" accept="image/*" class="d-none" />
            </div>
            <h5 class="mt-3 mb-0">@Model.Nombre</h5>
            <p class="text-muted-help mb-0">@Model.Titular</p>
            <p class="text-muted-help">@Model.Ubicacion</p>

            <div class="ds-profile-stats">
                <div>
                    <strong>@Model.TotalPreguntas</strong>
                    <span>preguntas</span>
                </div>
                <div>
                    <strong>@Model.TotalRespuestas</strong>
                    <span>respuestas</span>
                </div>
            </div>
            <p class="text-muted-help mt-3 mb-0">
                Miembro desde @Model.MiembroDesde.ToString("MMMM yyyy")
            </p>
        </div>
    </div>

    <div class="col-md-8">
        <div class="ds-form-section">
            <h5>Información básica</h5>

            @using (Html.BeginForm("Perfil", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                @Html.HiddenFor(m => m.UsuarioID)
                @Html.HiddenFor(m => m.AvatarUrl, new { id = "AvatarUrlHidden" })

                <div class="row">
                    <div class="form-group col-md-6">
                        @Html.LabelFor(m => m.Nombre)
                        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group col-md-6">
                        @Html.LabelFor(m => m.Correo)
                        @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", @readonly = "readonly" })
                        <span class="text-muted-help">El correo no se puede modificar todavía.</span>
                    </div>
                </div>

                <div class="form-group mt-3">
                    @Html.LabelFor(m => m.Titular)
                    @Html.TextBoxFor(m => m.Titular, new { @class = "form-control", maxlength = "120", placeholder = "Ej. Backend dev · .NET & SQL" })
                    @Html.ValidationMessageFor(m => m.Titular, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mt-3">
                    @Html.LabelFor(m => m.Biografia)
                    @Html.TextAreaFor(m => m.Biografia, new { @class = "form-control", rows = "3", maxlength = "280", placeholder = "Contale al foro en qué stack trabajás..." })
                    @Html.ValidationMessageFor(m => m.Biografia, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mt-3">
                    @Html.LabelFor(m => m.Ubicacion)
                    @Html.TextBoxFor(m => m.Ubicacion, new { @class = "form-control" })
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-ds-primary">Guardar cambios</button>
                    @Html.ActionLink("Cancelar", "Index", "Home", null, new { @class = "btn btn-ds-outline" })
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Vista previa del avatar en el cliente. Avance 2: solo se previsualiza,
        // todavia no se guarda el archivo binario.
        document.getElementById('avatarFileInput').addEventListener('change', function (e) {
            var file = e.target.files && e.target.files[0];
            if (!file) return;

            var reader = new FileReader();
            reader.onload = function (event) {
                var preview = document.getElementById('avatarPreview');
                preview.innerHTML = '<img src="' + event.target.result + '" alt="Avatar" id="avatarImg" />';
                document.getElementById('AvatarUrlHidden').value = event.target.result;
            };
            reader.readAsDataURL(file);
        });
    </script>
}